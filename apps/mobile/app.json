{
  "expo": {
    "name": "PAR-Tee",
    "slug": "par-tee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "par-tee",
    "description": "Book golf tee times based on your mood. Find courses that match how you want to play.",
    "keywords": [
      "golf",
      "tee time",
      "booking",
      "mood"
    ],
    "privacy": "https://par-tee.app/privacy",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a6b2a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.partee.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.partee.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a6b2a"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d006051c-c271-4d8b-8d11-5fb74c8d0971"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d006051c-c271-4d8b-8d11-5fb74c8d0971"
    }
  }
}
